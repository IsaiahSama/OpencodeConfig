{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "zai-org/glm-4.7-flash": {
          "name": "GLM 4.7 Flash (Local)"
        },
        "qwen/qwen3-coder-30b": {
          "name": "The Qwen3 Coder (Local)"
        },
        "qwen2.5-coder-7b-instruct": {
          "name": "The Speedy Qwen"
        },
        "deepseek-coder-6.7b-instruct": {
          "name": "Mr Deepseek"
        },
        "meta-llama-3.1-8b-instruct": {
          "name": "Llama"
        }
      }
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "rm *": "deny",
      "fd *": "allow",
      "rg *": "allow",
      "basedpyright *": "allow",
      "git add*": "allow",
      "git log*": "allow",
      "git status": "allow",
      "git diff": "allow"
    },
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "doom_loop": "allow",
    "webfetch": "allow",
    "websearch": "ask",
    "codesearch": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
  },
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "basedpyright": {
      "command": [
        "basedpyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  }
}
